{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    },
    "globals": ["Bun"]
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/vitest"
  ],
  "overrides": [
    {
      "includes": ["src/server/backends/stream-json-backend.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noVoid": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "useAwait": "off"
          },
          "style": {
            "noNestedTernary": "off",
            "useDefaultSwitchClause": "off"
          }
        }
      }
    },
    {
      "includes": ["src/server/index.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": ["src/web/src/hooks/use-agent.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noControlCharactersInRegex": "off"
          }
        }
      }
    },
    {
      "includes": ["src/web/src/components/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "noNoninteractiveElementInteractions": "off",
            "useFocusableInteractive": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off",
            "useValidAnchor": "off"
          },
          "performance": {
            "noNamespaceImport": "off"
          },
          "suspicious": {
            "noDocumentCookie": "off"
          }
        }
      }
    },
    {
      "includes": ["src/web/src/App.tsx"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["src/web/src/components/nav-workspaces.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useValidAnchor": "off"
          }
        }
      }
    },
    {
      "includes": [".agents/**/*.tsx", ".agents/**/*.ts"],
      "linter": {
        "rules": {
          "a11y": {
            "useMediaCaption": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    }
  ]
}
